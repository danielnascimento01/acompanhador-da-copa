{
  "expo": {
    "name": "Acompanhador da Copa",
    "slug": "acompanhador-copa-2026",
    "version": "1.1.0",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "scheme": "copa2026",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080B10",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B10"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "com.danielnascimento.copa2026",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.danielnascimento.copa2026",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080B10"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#14E08A"
        }
      ],
      "expo-font",
      [
        "expo-dynamic-app-icon",
        {
