{
  "expo": {
    "name": "Acompanhador da Copa",
    "slug": "acompanhador-copa-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "copa2026",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080B10",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B10"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "com.danielnascimento.copa2026"
    },
    "android": {
      "package": "com.danielnascimento.copa2026",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080B10"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#14E08A"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "thesportsdbLeagueId": "4429",
      "thesportsdbSeason": "2026"
    }
  }
}
